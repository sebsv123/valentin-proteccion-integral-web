# ─── Valentín Protección Integral ─── Environment Variables ───

# Site URL (used for sitemap, meta tags, OG images)
NEXT_PUBLIC_SITE_URL=https://valentinproteccionintegral.com

# Lead form endpoint (n8n webhook or custom API)
NEXT_PUBLIC_LEAD_ENDPOINT=

# Server-side lead endpoint for internal API routes
LEAD_WEBHOOK_URL=
LEAD_WEBHOOK_SECRET=

# Microsoft Clarity analytics
NEXT_PUBLIC_CLARITY_ID=

# ─── Vercel / Deployment ───
# Set these in GitHub Secrets for CI/CD
# VERCEL_TOKEN=
# VERCEL_ORG_ID=
# VERCEL_PROJECT_ID=
# Local/test lead delivery is blocked unless this is deliberately set to true.
# Do not enable it in automated tests.
ALLOW_LOCAL_LEAD_DELIVERY=false

# Vercel Preview Deployments and `vercel dev` (VERCEL_ENV=preview|development)
# are blocked from sending real SMTP by default, since preview URLs are
# shared/public. Set to true only for a specific Preview when a real-send
# check is deliberately needed; never enable it project-wide.
ALLOW_PREVIEW_LEAD_DELIVERY=false

# Server-only SMTP delivery for /api/leads and /api/professional-referral.
# Configure real values only in the deployment provider; never expose them as NEXT_PUBLIC_*.
SMTP_HOST=
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=
SMTP_APP_PASSWORD=
CONTACT_LEADS_EMAIL=
