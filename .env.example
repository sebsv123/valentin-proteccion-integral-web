# ─── Valentín Protección Integral ─── Environment Variables ───

# Site URL (used for sitemap, meta tags, OG images)
NEXT_PUBLIC_SITE_URL=https://valentinproteccionintegral.com

# Lead form endpoint (n8n webhook or custom API)
NEXT_PUBLIC_LEAD_ENDPOINT=

# Server-side lead endpoint for internal API routes
LEAD_WEBHOOK_URL=
LEAD_WEBHOOK_SECRET=

# Microsoft Clarity analytics
NEXT_PUBLIC_CLARITY_ID=

# ─── Vercel / Deployment ───
# Set these in GitHub Secrets for CI/CD
# VERCEL_TOKEN=
# VERCEL_ORG_ID=
# VERCEL_PROJECT_ID=
